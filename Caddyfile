# =============================================================================
# Caddyfile — AI Wisdom Battle Production (AWS Lightsail Singapore, IPv6-only)
# Frontend: Cloudflare Pages (free CDN)
# Backend:  Lightsail IPv6 — Caddy proxy /api/* đến Go backend port 8080
#
# TLS: Cloudflare DNS-01 challenge (không cần port 80/443 IPv4 public)
# User (IPv4/IPv6) → Cloudflare → IPv6 → Caddy → Go backend
#
# Reload config: docker exec awb-caddy caddy reload --config /etc/caddy/Caddyfile
# =============================================================================

{env.API_DOMAIN} {

    # ── TLS: Caddy auto-HTTPS via ACME HTTP-01 (Let's Encrypt) ───────────────
    # No tls block needed — Caddy obtains and renews cert automatically.
    # Requires port 80 to be publicly reachable for the HTTP-01 challenge.
    # If using Cloudflare proxy (orange-cloud), switch to DNS-01 instead:
    #   tls { dns cloudflare {env.CLOUDFLARE_API_TOKEN} }

    # ── Nén response ──────────────────────────────────────────────────────────
    encode gzip

    # ── API → Go backend :8080 ────────────────────────────────────────────────
    reverse_proxy app:8080 {
        health_uri      /health
        health_interval 15s
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }

    # ── Security headers ──────────────────────────────────────────────────────
    header {
        X-Content-Type-Options  nosniff
        X-Frame-Options         DENY
        X-XSS-Protection        "1; mode=block"
        Referrer-Policy         strict-origin-when-cross-origin
        -Server
    }

    # ── Logging ───────────────────────────────────────────────────────────────
    log {
        output stdout
        format json
        level  INFO
    }
}
