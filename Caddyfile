# =============================================================================
# Caddyfile — AI Knowledge Path Production (AWS Lightsail Singapore)
# Frontend: Cloudflare Pages (free CDN)
# Backend:  Lightsail — Caddy reverse proxy → Go backend port 8080
#
# TLS: ACME HTTP-01 (Let's Encrypt auto-HTTPS)
#   IMPORTANT: port 80 MUST be publicly reachable for HTTP-01 challenge.
#   Cert is renewed automatically every ~60 days — do NOT block port 80.
#   Domain is set via API_DOMAIN env var (e.g. <IP>.sslip.io or custom domain).
#
# Reload config: docker exec awb-caddy caddy reload --config /etc/caddy/Caddyfile
# =============================================================================

{$API_DOMAIN} {

    # ── TLS: Caddy auto-HTTPS via ACME HTTP-01 (Let's Encrypt) ───────────────
    # No tls block needed — Caddy obtains and renews cert automatically.
    # Requires port 80 to be publicly reachable for the HTTP-01 challenge.
    # If using Cloudflare proxy (orange-cloud), switch to DNS-01 instead:
    #   tls { dns cloudflare {env.CLOUDFLARE_API_TOKEN} }

    # ── Nén response ──────────────────────────────────────────────────────────
    encode gzip

    # ── API → Go backend :8080 ────────────────────────────────────────────────
    reverse_proxy app:8080 {
        health_uri      /health
        health_interval 15s
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }

    # ── Security headers ──────────────────────────────────────────────────────
    header {
        X-Content-Type-Options  nosniff
        X-Frame-Options         DENY
        X-XSS-Protection        "1; mode=block"
        Referrer-Policy         strict-origin-when-cross-origin
        -Server
    }

    # ── Logging ───────────────────────────────────────────────────────────────
    log {
        output stdout
        format json
        level  INFO
    }
}
