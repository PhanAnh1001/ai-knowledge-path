{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(mvn:*)",
      "Bash(gradle:*)",
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(python3:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | ./.claude/save-discussion.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
