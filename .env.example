# =============================================================================
# AI Knowledge Path — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
#   cp .env.example .env
# KHÔNG commit file .env lên git
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=ai-knowledge-path
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres

# ── Go Backend ────────────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=postgres://postgres:change_me_postgres@localhost:5432/ai-knowledge-path

# ── JWT (tối thiểu 32 ký tự) ──────────────────────────────────────────────────
# Tạo nhanh: openssl rand -base64 32
JWT_SECRET=change_me_at_least_32_chars_long!!!
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ── React Frontend ────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api/v1

# ── CORS (production: đặt domain frontend thật) ───────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting (auth endpoints only) ────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ── Caddy reverse proxy domain ────────────────────────────────────────────────
# Đặt subdomain cho API backend, ví dụ: api.your-domain.com
# Nếu không có custom domain, có thể dùng: <LIGHTSAIL_IP>.sslip.io (test only)
API_DOMAIN=api.your-domain.com

# ── Cloudflare (for Caddy DNS-01 challenge on Lightsail) ─────────────────────
# Chỉ cần khi API_DOMAIN là zone được quản lý trên Cloudflare.
# Nếu dùng sslip.io hoặc domain không qua Cloudflare, bỏ trống hoặc giữ placeholder.
CLOUDFLARE_API_TOKEN=change_me_cloudflare_token

# ── Versioning / Registry (dùng trong docker-compose.prod.yml) ────────────────
GHCR_REPO=phanAnh1001/ai-knowledge-path
IMAGE_TAG=latest
