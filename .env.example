# =============================================================================
# AI Wisdom Battle — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
#   cp .env.example .env
# KHÔNG commit file .env lên git
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=ai_wisdom_battle
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379

# ── Spring Boot App ────────────────────────────────────────────────────────────
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ── JWT (tối thiểu 32 ký tự) ──────────────────────────────────────────────────
# Tạo nhanh: openssl rand -base64 32
JWT_SECRET=change_me_at_least_32_chars_long!!!
JWT_EXPIRATION_MS=86400000

# ── Python Adaptive Engine ────────────────────────────────────────────────────
ADAPTIVE_ENGINE_PORT=8001
INTERNAL_API_KEY=change_me_internal_key

# ── React Frontend ────────────────────────────────────────────────────────────
FRONTEND_PORT=80
VITE_API_BASE_URL=/api/v1
