# =============================================================================
# terraform.tfvars.example — Sao chép thành terraform.tfvars rồi điền giá trị
# KHÔNG commit terraform.tfvars lên Git!
# =============================================================================

# AWS Region — Singapore
aws_region = "ap-southeast-1"

# Lightsail bundle: nano_3_0 = 2 vCPU · 2 GB RAM · 60 GB SSD · $7/tháng
bundle_id = "nano_3_0"

# SSH public key — nội dung file ~/.ssh/awb-lightsail.pub
# Tạo: ssh-keygen -t ed25519 -C "awb-lightsail-deploy" -f ~/.ssh/awb-lightsail
ssh_public_key = "ssh-ed25519 AAAA... awb-lightsail-deploy"
