# =============================================================================
# terraform.tfvars.example — Sao chép thành terraform.tfvars rồi điền giá trị
# KHÔNG commit terraform.tfvars lên Git!
# =============================================================================

# AWS Region — Singapore
aws_region = "ap-southeast-1"

# Lightsail bundle: small_ipv6_3_0 = 2 vCPU · 2 GB RAM · 60 GB SSD · $10/tháng (IPv6-only)
# IPv6-only instance BẮT BUỘC dùng bundle _ipv6_ — bundle standard (small_3_0) sẽ báo lỗi InvalidInputException
bundle_id = "small_ipv6_3_0"

# SSH public key — nội dung file ~/.ssh/awb-lightsail.pub
# Tạo: ssh-keygen -t rsa -b 4096 -C "awb-lightsail-deploy" -f ~/.ssh/awb-lightsail
# Lưu ý: Lightsail chỉ hỗ trợ RSA key, KHÔNG dùng ed25519
ssh_public_key = "ssh-rsa AAAA... awb-lightsail-deploy"
