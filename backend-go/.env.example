# =============================================================================
# AI Knowledge Path — Go Backend Environment Variables
# cp .env.example .env
# DO NOT commit .env to git
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:change_me@localhost:5432/ai-knowledge-path

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── JWT (at least 32 characters) ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change_me_at_least_32_chars_long!!!
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ── CORS (production: set real frontend domain) ────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://aiwisdombattle.com

# ── Rate Limiting (auth endpoints only) ───────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# ── Migrations ─────────────────────────────────────────────────────────────────
MIGRATIONS_PATH=/app/internal/db/migrations

# ── Cloudflare (for Caddy DNS challenge) ──────────────────────────────────────
CLOUDFLARE_API_TOKEN=change_me_cloudflare_token
